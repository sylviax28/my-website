# Copy to .env and fill in your values (do not commit .env)

# Gmail: use your email and an App Password (Google Account → Security → 2-Step Verification → App passwords)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password

# Where contact form messages should be sent (defaults to EMAIL_USER if not set)
CONTACT_EMAIL=your@gmail.com

# Optional: override SMTP (defaults to Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
